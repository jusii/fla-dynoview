{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FLA Dynoview",
  "version": "0.1.0",
  "identifier": "com.fladynoview.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FLA Dynoview",
        "width": 1180,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Bosch FLA 203 dyno run viewer",
    "longDescription": "Read dyno runs from a Bosch FLA 203 floppy image (.img) or .ERG file, browse and archive them locally, and print or export a clean PDF report.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
